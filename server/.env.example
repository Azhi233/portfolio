# Server
PORT=8787
JWT_SECRET=replace_with_a_long_random_secret

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=mywebsite
DB_PASSWORD=replace_with_a_new_secure_password
DB_NAME=mywebsite

# Local files
LOCAL_UPLOAD_DIR=./uploads

# MinIO
MINIO_ENABLED=false
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=replace_with_a_new_access_key
MINIO_SECRET_KEY=replace_with_a_new_secret_key
MINIO_BUCKET=portfolio
MINIO_PUBLIC_BASE_URL=
PUBLIC_FILE_BASE_URL=
MINIO_PRESIGN_EXPIRES_SECONDS=2592000
MINIO_UPLOAD_PREFIX=portfolio
