PORT=8787
JWT_SECRET=replace_with_a_long_random_secret

# ===== 本地存储（默认开启） =====
# 上传文件会保存到 server/uploads 目录，并通过 /uploads 对外访问
LOCAL_UPLOAD_DIR=./uploads

# ===== MinIO 配置（可选） =====
# 启用后，/api/uploads/local 会优先写入 MinIO
MINIO_ENABLED=false
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=zhizhi
MINIO_SECRET_KEY=zhizhi233
MINIO_BUCKET=portfolio

# 如果你的 MinIO 使用了反向代理/CDN，可填写公开访问基础地址
# 例如：https://minio.example.com
MINIO_PUBLIC_BASE_URL=

# 如果你有自己的文件域名，也可以给本地存储生成对外访问地址
PUBLIC_FILE_BASE_URL=

# 签名 URL 有效期（秒）
MINIO_PRESIGN_EXPIRES_SECONDS=3600

# 对象名前缀
MINIO_UPLOAD_PREFIX=portfolio
