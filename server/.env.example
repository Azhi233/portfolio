# Server environment variables
PORT=8788
JWT_SECRET=change-me-to-a-long-random-string

# Frontend origins allowed to call the API.
# Include the Vite dev/preview ports you use locally.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5178,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175,http://127.0.0.1:5176,http://127.0.0.1:5178,http://127.0.0.1:4173

# MySQL / Baota database configuration
# If your database runs in Baota on the same server, keep DB_HOST=127.0.0.1.
# If it is remote, replace DB_HOST with the remote IP or domain.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# Local file storage
LOCAL_UPLOAD_DIR=./uploads

# MinIO configuration
MINIO_ENABLED=true
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=portfolio
MINIO_UPLOAD_PREFIX=portfolio
MINIO_PRESIGN_EXPIRES_SECONDS=2592000
