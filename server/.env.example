PORT=8787

# ===== OSS 基本信息（阿里云 OSS 控制台） =====
OSS_BUCKET=your_bucket_name
OSS_REGION=oss-cn-shanghai

# 上传目录前缀（可选）
OSS_DIR_PREFIX=portfolio

# 前端 policy 过期时间（秒）
OSS_POLICY_EXPIRE_SECONDS=120

# ===== STS 配置（阿里云 RAM + STS） =====
# 1) 下面这组 AK/SK 是“调用 STS AssumeRole”的 RAM 用户凭证
# 2) 这个 RAM 用户本身不直接上传 OSS，只负责换取临时凭证
OSS_STS_ACCESS_KEY_ID=your_sts_caller_ak
OSS_STS_ACCESS_KEY_SECRET=your_sts_caller_sk

# 可被扮演的 RAM 角色 ARN（该角色需要 OSS PutObject 权限）
# 示例：acs:ram::123456789012****:role/your-oss-upload-role
OSS_STS_ROLE_ARN=acs:ram::your_account_id:role/your_upload_role

# STS 会话名（可选）
OSS_STS_ROLE_SESSION_NAME=portfolio-web-upload

# STS 临时凭证时长（秒，最小一般 900）
OSS_STS_DURATION_SECONDS=900
