# Server environment variables
PORT=8787

# Remote Baota/MySQL configuration
# Replace these with the database host/user/password/database from your Baota panel.
DB_HOST=your-baota-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name
JWT_SECRET=change-me

# MinIO configuration
MINIO_ENABLED=true
MINIO_ENDPOINT=your-minio-host
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key
MINIO_BUCKET=portfolio
MINIO_UPLOAD_PREFIX=portfolio
MINIO_PRESIGN_EXPIRES_SECONDS=2592000
